#include <bits/stdc++.h>
using namespace std;

/*---------------------------------------------------
1. Normal Comparator Function (Ascending)
---------------------------------------------------*/
bool cmpAscending(int a, int b)
{
    return a < b;
}

/*---------------------------------------------------
2. Descending Comparator
---------------------------------------------------*/
bool cmpDescending(int a, int b)
{
    return a > b;
}

/*---------------------------------------------------
3. Pair Comparator (Sort by First Element)
---------------------------------------------------*/
bool cmpPairFirst(pair<int,int> a, pair<int,int> b)
{
    return a.first < b.first;
}

/*---------------------------------------------------
4. Pair Comparator (Sort by Second Element)
---------------------------------------------------*/
bool cmpPairSecond(pair<int,int> a, pair<int,int> b)
{
    return a.second < b.second;
}

/*---------------------------------------------------
5. Multiple Condition Comparator
First ascending, if equal → second descending
---------------------------------------------------*/
bool cmpPairComplex(pair<int,int> a, pair<int,int> b)
{
    if(a.first == b.first)
        return a.second > b.second;

    return a.first < b.first;
}

/*---------------------------------------------------
6. Struct Comparator
---------------------------------------------------*/
struct Node
{
    int a;
    int b;
};

bool cmpStruct(Node x, Node y)
{
    return x.a < y.a;
}

/*---------------------------------------------------
7. Absolute Value Comparator
---------------------------------------------------*/
bool cmpAbs(int a, int b)
{
    return abs(a) < abs(b);
}

/*---------------------------------------------------
8. Priority Queue Custom Comparator (Functor)
---------------------------------------------------*/
struct pqComparator
{
    bool operator()(int a, int b)
    {
        return a > b; // makes min heap
    }
};

int main()
{
    vector<int> v = {5,2,8,1,9};
    vector<pair<int,int>> vp = {{3,4},{1,7},{3,2},{2,5},{1,9}};

    /*---------------------------------------------------
    Using Normal Comparator
    ---------------------------------------------------*/
    sort(v.begin(), v.end(), cmpAscending);

    /*---------------------------------------------------
    Using Descending Comparator
    ---------------------------------------------------*/
    sort(v.begin(), v.end(), cmpDescending);

    /*---------------------------------------------------
    Using Pair Comparator (first element)
    ---------------------------------------------------*/
    sort(vp.begin(), vp.end(), cmpPairFirst);

    /*---------------------------------------------------
    Using Pair Comparator (second element)
    ---------------------------------------------------*/
    sort(vp.begin(), vp.end(), cmpPairSecond);

    /*---------------------------------------------------
    Using Multiple Condition Comparator
    ---------------------------------------------------*/
    sort(vp.begin(), vp.end(), cmpPairComplex);

    /*---------------------------------------------------
    Lambda Comparator (Descending)
    ---------------------------------------------------*/
    sort(v.begin(), v.end(), [](int a, int b){
        return a > b;
    });

    /*---------------------------------------------------
    Lambda Comparator for Pair
    ---------------------------------------------------*/
    sort(vp.begin(), vp.end(), [](pair<int,int> a, pair<int,int> b){

        if(a.first == b.first)
            return a.second > b.second;

        return a.first < b.first;
    });

    /*---------------------------------------------------
    Generic Lambda Comparator (Modern C++)
    ---------------------------------------------------*/
    sort(vp.begin(), vp.end(), [](auto &a, auto &b){
        return a.second < b.second;
    });

    /*---------------------------------------------------
    Priority Queue Default (Max Heap)
    ---------------------------------------------------*/
    priority_queue<int> pq;

    /*---------------------------------------------------
    Priority Queue Min Heap
    ---------------------------------------------------*/
    priority_queue<int, vector<int>, greater<int>> minpq;

    /*---------------------------------------------------
    Priority Queue Custom Comparator
    ---------------------------------------------------*/
    priority_queue<int, vector<int>, pqComparator> custompq;

    return 0;
}
