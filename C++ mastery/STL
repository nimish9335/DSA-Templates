#include <bits/stdc++.h>
using namespace std;

int main()
{

/*---------------------------------------------------
1. VECTOR (Dynamic Array)
---------------------------------------------------*/
vector<int> v = {1,2,3};

v.push_back(4);      // add element
v.pop_back();        // remove last

cout << "Vector elements: ";
for(int x : v)
    cout << x << " ";
cout << endl;


/*---------------------------------------------------
2. STACK (LIFO)
---------------------------------------------------*/
stack<int> st;

st.push(10);
st.push(20);
st.push(30);

cout << "Stack top: " << st.top() << endl;

st.pop(); // remove top


/*---------------------------------------------------
3. QUEUE (FIFO)
---------------------------------------------------*/
queue<int> q;

q.push(1);
q.push(2);
q.push(3);

cout << "Queue front: " << q.front() << endl;

q.pop();


/*---------------------------------------------------
4. DEQUE (Double Ended Queue)
---------------------------------------------------*/
deque<int> dq;

dq.push_back(5);
dq.push_front(2);

cout << "Deque elements: ";
for(int x : dq)
    cout << x << " ";
cout << endl;


/*---------------------------------------------------
5. PRIORITY QUEUE (MAX HEAP by default)
---------------------------------------------------*/
priority_queue<int> pq;

pq.push(10);
pq.push(5);
pq.push(20);

cout << "Priority Queue top: " << pq.top() << endl;


/*---------------------------------------------------
6. PRIORITY QUEUE (MIN HEAP)
---------------------------------------------------*/
priority_queue<int, vector<int>, greater<int>> minpq;

minpq.push(10);
minpq.push(5);
minpq.push(20);

cout << "Min Heap top: " << minpq.top() << endl;


/*---------------------------------------------------
7. SET (Unique elements, sorted)
---------------------------------------------------*/
set<int> s;

s.insert(5);
s.insert(1);
s.insert(3);

cout << "Set elements: ";
for(int x : s)
    cout << x << " ";
cout << endl;


/*---------------------------------------------------
8. UNORDERED SET (Hash based)
---------------------------------------------------*/
unordered_set<int> us;

us.insert(10);
us.insert(20);
us.insert(10);


/*---------------------------------------------------
9. MAP (Key-Value, sorted by key)
---------------------------------------------------*/
map<int,string> mp;

mp[1] = "apple";
mp[2] = "banana";

cout << "Map elements:" << endl;
for(auto x : mp)
    cout << x.first << " " << x.second << endl;


/*---------------------------------------------------
10. UNORDERED MAP (Hash table)
---------------------------------------------------*/
unordered_map<int,int> ump;

ump[1] = 10;
ump[2] = 20;


/*---------------------------------------------------
11. MULTISET (Allows duplicates)
---------------------------------------------------*/
multiset<int> ms;

ms.insert(5);
ms.insert(5);
ms.insert(2);


/*---------------------------------------------------
12. ALGORITHMS (sort, reverse, max_element)
---------------------------------------------------*/
vector<int> arr = {4,2,8,1};

sort(arr.begin(), arr.end());

reverse(arr.begin(), arr.end());

cout << "Max element: " << *max_element(arr.begin(), arr.end()) << endl;


/*---------------------------------------------------
13. BINARY SEARCH
---------------------------------------------------*/
sort(arr.begin(), arr.end());

if(binary_search(arr.begin(), arr.end(), 4))
    cout << "4 found" << endl;


/*---------------------------------------------------
14. COUNT FUNCTION
---------------------------------------------------*/
cout << "Count of 2: " << count(arr.begin(), arr.end(), 2) << endl;


/*---------------------------------------------------
15. ITERATORS
---------------------------------------------------*/
cout << "Using iterator: ";

for(auto it = arr.begin(); it != arr.end(); it++)
    cout << *it << " ";

cout << endl;

}
