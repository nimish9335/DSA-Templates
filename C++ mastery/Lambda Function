#include <bits/stdc++.h>
using namespace std;

int main()
{

/*---------------------------------------------------
1. Basic Lambda Function
---------------------------------------------------*/
auto add = [](int a, int b){
    return a + b;
};
cout << "Add: " << add(3,4) << endl;


/*---------------------------------------------------
2. Lambda Without Parameters
---------------------------------------------------*/
auto hello = [](){
    cout << "Hello Lambda" << endl;
};
hello();


/*---------------------------------------------------
3. Lambda With Explicit Return Type
---------------------------------------------------*/
auto divide = [](double a, double b) -> double {
    return a / b;
};
cout << "Divide: " << divide(10,2) << endl;


/*---------------------------------------------------
4. Lambda Used in Sorting (Descending)
---------------------------------------------------*/
vector<int> v = {4,1,8,3,2};

sort(v.begin(), v.end(), [](int a, int b){
    return a > b;
});

cout << "Sorted Desc: ";
for(int x : v) cout << x << " ";
cout << endl;


/*---------------------------------------------------
5. Lambda Comparator for Pair Sorting
Rule: first ascending, second descending
---------------------------------------------------*/
vector<pair<int,int>> vp = {{3,4},{1,7},{3,2},{2,5},{1,9}};

sort(vp.begin(), vp.end(), [](pair<int,int> a, pair<int,int> b){

    if(a.first == b.first)
        return a.second > b.second;

    return a.first < b.first;
});

cout << "Pair Sorted: ";
for(auto p : vp)
    cout << "(" << p.first << "," << p.second << ") ";
cout << endl;


/*---------------------------------------------------
6. Generic Lambda (Modern C++)
---------------------------------------------------*/
sort(vp.begin(), vp.end(), [](auto &a, auto &b){
    return a.second < b.second;
});


/*---------------------------------------------------
7. Lambda Capture by Value
---------------------------------------------------*/
int x = 10;

auto captureValue = [x](int y){
    return x + y;
};

cout << "Capture by value: " << captureValue(5) << endl;


/*---------------------------------------------------
8. Lambda Capture by Reference
---------------------------------------------------*/
int y = 5;

auto captureRef = [&y](){
    y++;
};

captureRef();
cout << "Capture by reference: " << y << endl;


/*---------------------------------------------------
9. Capture All Variables by Value
---------------------------------------------------*/
int a = 2, b = 3;

auto f1 = [=](){
    return a + b;
};

cout << "Capture all by value: " << f1() << endl;


/*---------------------------------------------------
10. Capture All Variables by Reference
---------------------------------------------------*/
int c = 5, d = 6;

auto f2 = [&](){
    c++;
    d++;
};

f2();
cout << "Capture all by ref: " << c << " " << d << endl;


/*---------------------------------------------------
11. Lambda for Absolute Value Sorting
---------------------------------------------------*/
vector<int> arr = {-10,5,-2,8};

sort(arr.begin(), arr.end(), [](int a, int b){
    return abs(a) < abs(b);
});

cout << "Sort by abs: ";
for(int x : arr) cout << x << " ";
cout << endl;


/*---------------------------------------------------
12. Lambda Used in Priority Queue Comparator
---------------------------------------------------*/
auto cmp = [](int a, int b){
    return a > b;
};

priority_queue<int, vector<int>, decltype(cmp)> pq(cmp);

pq.push(5);
pq.push(2);
pq.push(8);

cout << "Priority Queue (min heap): ";
while(!pq.empty()){
    cout << pq.top() << " ";
    pq.pop();
}
cout << endl;

}
